# =============================================================================
# Server 1 (Control Node) — Environment Variables
# 复制为 .env 并填写所有必填项
#   cp deploy/.env.server1.example .env
# =============================================================================

# =============================================
# [必填] Leverage Backend — 应用配置
# =============================================
NODE_ENV=production
PORT=3000

# =============================================
# [必填] MariaDB
# =============================================
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=leverage
DB_USERNAME=leverage
DB_PASSWORD=change_me_strong_db_password
DB_ROOT_PASSWORD=change_me_strong_root_password
DB_POOL_SIZE=20
DB_QUERY_TIMEOUT=10000

# =============================================
# [必填] JWT 密钥（openssl rand -hex 32 生成）
# =============================================
JWT_ACCESS_SECRET=change_me_32char_access_secret_here
JWT_REFRESH_SECRET=change_me_32char_refresh_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# =============================================
# [必填] 公网地址（leverage-backend 的公网 URL）
# 用于 botzone-neo 回调时 leverage-backend 可达
# =============================================
BASE_URL=https://your-domain.com

# =============================================
# [必填] Botzone-Neo 配置
# =============================================
BOTZONE_ENABLED=true
# leverage-backend → botzone-neo 的内网调用地址（docker 内部服务名）
BOTZONE_BASE_URL=http://botzone-neo:3001
# botzone-neo 调用 leverage-backend 回调的地址（公网或 Tailscale 可达）
BOTZONE_CALLBACK_URL=https://your-domain.com/api/judge/callback
# leverage-backend 向 botzone-neo 发请求时携带的 API Key
BOTZONE_API_KEY=change_me_botzone_api_key
# botzone-neo 回调 leverage-backend 时携带的 Token（lever 侧校验）
# 生成：openssl rand -hex 32
BOTZONE_CALLBACK_TOKEN=change_me_botzone_callback_token
BOTZONE_DEFAULT_PROBLEM_ID=
BOTZONE_POLL_INTERVAL_MS=30000

# =============================================
# [必填] Redis
# =============================================
REDIS_HOST=redis
REDIS_PORT=6379
# ⚠️  生产环境强烈建议设置密码！
# 生成：openssl rand -hex 32
REDIS_PASSWORD=change_me_redis_password

# Redis 对外绑定 IP（Tailscale IP，让 Worker 服务器可连接）
# 设置为 Server 1 的 Tailscale IP，例如：100.73.231.27
# 留空则只监听 127.0.0.1（Worker 无法连接）
REDIS_BIND_IP=100.x.x.x

# =============================================
# Botzone-Neo Worker（co-located on Server 1）
# =============================================
JUDGE_CONCURRENCY=15
COMPILE_TIME_LIMIT_MS=10000
COMPILE_CACHE_SIZE=200
MAX_MATCH_DURATION_MS=300000
SANDBOX_BACKEND=nsjail
NSJAIL_PATH=/usr/bin/nsjail

# =============================================
# CORS / 安全
# =============================================
CORS_ORIGIN=https://your-domain.com

# =============================================
# 初始 SA 账号（首次启动使用，之后立即修改密码）
# =============================================
INIT_SA_USERNAME=admin
INIT_SA_PASSWORD=Change_Me_Admin_Password!

# =============================================
# 可观测性（可选）
# =============================================
OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# OTEL_SERVICE_NAME=leverage-backend

# =============================================
# 限流
# =============================================
MAX_SUBMISSION_PER_MINUTE=10

# =============================================
# Worker 资源限制（可选，覆盖 docker-compose 默认值）
# =============================================
# WORKER_CPU_LIMIT=4
# WORKER_MEM_LIMIT=4G
