# =============================================================================
# Server 2..N (Worker Node) — Environment Variables
# 复制为 .env 并填写所有必填项
#   cp deploy/.env.worker.example .env
# =============================================================================

# =============================================
# [必填] Redis 连接（指向 Server 1）
# =============================================
# Server 1 的 Tailscale IP（推荐）或公网 IP
REDIS_HOST=100.x.x.x
REDIS_PORT=6379
# 必须与 Server 1 的 REDIS_PASSWORD 一致
REDIS_PASSWORD=change_me_redis_password

# =============================================
# [必填] Botzone-Neo Worker 配置
# =============================================
PORT=3001
NODE_ENV=production

# 并发数：根据服务器 CPU 核数调整
# 建议：JUDGE_CONCURRENCY = CPU 核数 × 2 ~ 4
JUDGE_CONCURRENCY=15

COMPILE_TIME_LIMIT_MS=10000
COMPILE_CACHE_SIZE=200
MAX_MATCH_DURATION_MS=300000
SANDBOX_BACKEND=nsjail
NSJAIL_PATH=/usr/bin/nsjail

# =============================================
# [可选] botzone-neo 回调地址
# Worker 节点通常不直接接收回调，回调由 Server 1 的 leverage-backend 处理。
# 如需 Worker 直接回调，填写 leverage-backend 的公网地址：
# BOTZONE_CALLBACK_URL=https://your-domain.com/api/judge/callback
# BOTZONE_CALLBACK_TOKEN=（与 Server 1 相同的 Token）
# =============================================

# =============================================
# Docker 镜像（可选，使用预构建镜像时填写）
# =============================================
# BOTZONE_IMAGE=ghcr.io/yourorg/botzone-neo:latest

# =============================================
# Worker 资源限制（可选）
# =============================================
# WORKER_CPU_LIMIT=4
# WORKER_MEM_LIMIT=4G
