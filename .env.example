# ======================
# 服务配置
# ======================
PORT=3001
NODE_ENV=development

# ======================
# Redis
# ======================
REDIS_HOST=redis
REDIS_PORT=6379

# ======================
# 评测配置
# ======================
JUDGE_CONCURRENCY=15             # Bull 队列并发数
COMPILE_TIME_LIMIT_MS=10000      # 编译超时（毫秒）
COMPILE_CACHE_SIZE=200           # 编译缓存条目上限
MAX_MATCH_DURATION_MS=300000     # 单场对局最大时长（毫秒，默认 5 分钟）
SANDBOX_BACKEND=nsjail           # nsjail | direct
NSJAIL_PATH=/usr/bin/nsjail      # nsjail 二进制路径

# ======================
# 安全
# ======================
TRUST_IP=127.0.0.1               # 允许提交评测任务的 IP（逗号分隔）
CORS_ORIGIN=*                    # CORS 允许的来源（* 或具体域名）

# ======================
# 可观测性
# ======================
OTEL_ENABLED=false               # 启用 OpenTelemetry（true | false）
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=botzone-neo
